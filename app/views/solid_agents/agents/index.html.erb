<div class="card">
  <h2>Agents</h2>
  <table>
    <thead>
      <tr>
        <th>Key</th>
        <th>Name</th>
        <th>Role</th>
        <th>Runtime</th>
        <th>Env</th>
        <th>Enabled</th>
      </tr>
    </thead>
    <tbody>
      <% @agents.each do |agent| %>
        <tr>
          <td><%= link_to agent.key, agent_path(agent) %></td>
          <td><%= agent.name %></td>
          <td><%= agent.role %></td>
          <td><%= agent.runtime %></td>
          <td><%= agent.environment || "all" %></td>
          <td><%= agent.enabled? ? "yes" : "no" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
