<style>
  :root {
    --bg: #f4f7fb;
    --surface: #ffffff;
    --ink: #17202a;
    --muted: #5e6b78;
    --line: #dbe4ee;
    --accent: #0f766e;
    --good: #166534;
    --bad: #b91c1c;
    --run: #7c3aed;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: radial-gradient(circle at 5% 0%, #d7f7f0 0%, transparent 35%), var(--bg);
    color: var(--ink);
  }

  .wrap { width: min(1100px, 94vw); margin: 0 auto; }

  .topbar {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    margin-bottom: 1.25rem;
  }

  .topbar .wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .8rem 0;
  }

  .topbar h1 {
    font-size: 1.1rem;
    margin: 0;
    letter-spacing: .02em;
  }

  .topbar nav { display: flex; gap: .75rem; }

  .topbar a {
    color: var(--ink);
    text-decoration: none;
    padding: .35rem .65rem;
    border-radius: .5rem;
    border: 1px solid transparent;
  }

  .topbar a:hover { border-color: var(--line); background: #f8fbff; }

  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: .9rem;
    padding: 1rem;
    margin-bottom: 1rem;
    box-shadow: 0 1px 0 rgba(16,24,40,.02);
  }

  table { width: 100%; border-collapse: collapse; }

  th, td {
    text-align: left;
    padding: .65rem .5rem;
    border-bottom: 1px solid var(--line);
    font-size: .93rem;
  }

  th { color: var(--muted); font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; }

  .badge {
    display: inline-block;
    padding: .2rem .55rem;
    border-radius: .55rem;
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .badge.ok { background: #dcfce7; color: var(--good); }
  .badge.err { background: #fee2e2; color: var(--bad); }
  .badge.run { background: #ede9fe; color: var(--run); }
  .badge.muted { background: #eef2f7; color: var(--muted); }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .flash {
    padding: .6rem .8rem;
    border-radius: .65rem;
    border: 1px solid var(--line);
  }

  .notice { background: #ecfeff; }
  .alert { background: #fff7ed; }

  .btn {
    display: inline-block;
    border: 1px solid var(--line);
    background: #fff;
    color: var(--ink);
    border-radius: .55rem;
    padding: .45rem .7rem;
    text-decoration: none;
    cursor: pointer;
  }

  .btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }

  pre {
    background: #0b1220;
    color: #d1e0ff;
    border-radius: .8rem;
    padding: .85rem;
    overflow: auto;
    font-size: .82rem;
  }

  @media (max-width: 800px) {
    .grid { grid-template-columns: 1fr; }
    th:nth-child(4), td:nth-child(4) { display: none; }
  }
</style>
